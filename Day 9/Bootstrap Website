<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=Edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <title>Bakery</title>

        <style>
            header.site-header {
                min-height: 70px;
                max-height: 70px;
                height: 70px;
            }
            header.site-header .header-row {
                flex-wrap: nowrap !important;
                align-items: center;
            }
            header.site-header .logo-image {
                max-height: 70px;
                width: auto;
                object-fit: contain;
            }
            header.site-header .nav-link {
                padding: 0.35rem 0.75rem;
            }
            header.site-header .header-actions {
                gap: 0.5rem;
            }
            header.site-header .container {
                max-width: 100%;
            }

            .carousel-control-prev,
            .carousel-control-next {
                width: 3.5rem;
                height: 5rem;
                border-radius: 10%;
                background-color: rgba(0, 0, 0, 0.7);
                top: 50%;
                transform: translateY(-50%);
            }
            .carousel-control-prev {
                left: 0;
            }
            .carousel-control-next {
                right: 0;
            }
            .carousel-control-prev-icon,
            .carousel-control-next-icon {
                filter: none;
                background-size: 1.5rem 1.5rem;
            }
        </style>
    </head>

    <body>
        <header class="bg-dark site-header">
            <div class="container">
                <div class="d-flex header-row align-items-center justify-content-between gap-3">
                    <a href="Web.html" class="d-flex align-items-center mb-2 mb-md-0 text-decoration-none">
                        <img src="Images\logo.png" alt="CoffeeBreak Logo" class="img-fluid logo-image" />
                    </a>

                    <nav class="nav nav-pills gap-2 mb-2 mb-md-0">
                        <a class="nav-link text-white active" href="Web.html">Home</a>
                        <a class="nav-link text-white" href="menu.html">Menu</a>
                        <a class="nav-link text-white" href="#order">Order</a>
                        <a class="nav-link text-white" href="contact.html">Contact Us</a>
                    </nav>

                    <div class="d-flex flex-nowrap align-items-center gap-2">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white border-end-0"><svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" fill="currentColor"><path d="M21.53 20.47l-3.66-3.66C19.195 15.24 20 13.214 20 11c0-4.97-4.03-9-9-9s-9 4.03-9 9 4.03 9 9 9c2.215 0 4.24-.804 5.808-2.13l3.66 3.66c.147.146.34.22.53.22s.385-.073.53-.22c.295-.293.295-.767.002-1.06zM3.5 11c0-4.135 3.365-7.5 7.5-7.5s7.5 3.365 7.5 7.5-3.365 7.5-7.5 7.5-7.5-3.365-7.5-7.5z"></path></svg></span>
                            <input id="query" class="form-control form-control-sm border-start-0" type="search" placeholder="Search..." name="searchbar" />
                        </div>
                        <a href="signup.html" class="btn btn-outline-light btn-sm">Login</a>
                    </div>
                </div>
            </div>
        </header>

        <section class="second position-relative overflow-hidden bg-dark">
            <div id="foodCarousel" class="carousel slide" data-bs-ride="carousel" style="min-height: 60vh;">
                <div class="carousel-inner h-100">
                    <div class="carousel-item active h-50">
                        <img src="Images\coffee.png" class="d-block w-100 h-100 object-fit-cover" alt="Coffee">
                    </div>
                    <div class="carousel-item h-50">
                        <img src="Images\chocolate.png" class="d-block w-100 h-100 object-fit-cover" alt="Chocolate">
                    </div>
                    <div class="carousel-item h-50">
                        <img src="Images\croissant.png" class="d-block w-100 h-100 object-fit-cover" alt="Croissant">
                    </div>
                    <div class="carousel-item h-50">
                        <img src="Images\macaron.png" class="d-block w-100 h-100 object-fit-cover" alt="Macaron">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#foodCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#foodCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
        </section>
             
        <div class="container my-5">
            <div class="table-responsive shadow-sm rounded-4 overflow-hidden">
                <table class="table table-striped table-bordered table-hover align-middle mb-0">
                    <thead class="table-dark text-center text-uppercase">
                        <tr>
                            <th scope="col">SR No.</th>
                            <th scope="col">Categories</th>
                            <th scope="col">Items</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        <tr>
                            <td>1.</td>
                            <td>Chocolate</td>
                            <td>Dark, Milk, Roasted Almond</td>
                        </tr>
                    <tr>
                        <td>2.</td>
                        <td>Coffee</td>
                        <td>Dark Roasted,
                            Cappuccino
                        </td>
                    </tr>
                    <tr>
                        <td>3.</td>
                        <td>Croissant</td>
                        <td>Classic,
                            Choco Filled,
                            Pistachio 
                        </td>
                    </tr>
                    <tr>
                        <td>4.</td>
                        <td>Macaron</td>
                        <td>Blackcurrant,
                            Vanilla,
                            Bergamot
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <section class="contact py-5 bg-light">
            <div class="container">
                <div class="page-wrapper">
                    <div class="text-center mb-5">
                        <h1 class="fw-bold">Contact Us</h1>
                        <p class="text-muted mx-auto" style="max-width: 680px;">Need help or want to work together? Send us a message and we will get back to you within one business day.</p>
                    </div>

                    <div class="row g-4">
                        <section class="panel col-12 col-lg-6 p-4 rounded-4 shadow-sm bg-white">
                            <h2 class="h4">Let's connect</h2>
                            <p class="text-muted">Whether you have a question, feedback, or need support, our team is ready to help. Reach out by email, phone, whatsapp, or via the form.</p>

                            <div class="contact-details row row-cols-1 gy-3">
                                <div class="detail-item p-3 border rounded-4 bg-light">
                                    <strong class="d-block mb-2">Email</strong>
                                    <a href="mailto:recipient@example.com" class="text-decoration-none text-dark">hello@example.com</a>
                                </div>
                                <div class="detail-item p-3 border rounded-4 bg-light">
                                    <strong class="d-block mb-2">Phone</strong>
                                    <a href="tel:+911234567890" class="text-decoration-none text-dark">+91 1234567890</a>
                                </div>
                                <div class="detail-item p-3 border rounded-4 bg-light">
                                    <strong class="d-block mb-2">Whatsapp</strong>
                                    <a href="https://wa.me/911234567890" class="text-decoration-none text-dark">+91 1234567890</a>
                                </div>
                                <div class="detail-item p-3 border rounded-4 bg-light">
                                    <strong class="d-block mb-2">Office</strong>
                                    <a href="https://maps.google.com/?q=1234+Digital+Avenue,+Suite+100,+Cityville" target="_blank" class="text-decoration-none text-dark">1234 Digital Avenue, Suite 100, Cityville</a>
                                </div>
                            </div>
                        </section>

                        <section class="panel col-12 col-lg-6 p-4 rounded-4 shadow-sm bg-white">
                            <h2 class="h4">Send a message</h2>
                            <form action="#" method="post" class="row g-3 mt-3">
                                <div class="col-12">
                                    <label for="name" class="form-label">Name</label>
                                    <input type="text" id="name" name="name" class="form-control" placeholder="Your name" required>
                                </div>
                                <div class="col-12">
                                    <label for="email" class="form-label">Email</label>
                                    <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
                                </div>
                                <div class="col-12">
                                    <label for="subject" class="form-label">Subject</label>
                                    <input type="text" id="subject" name="subject" class="form-control" placeholder="What would you like to discuss?" required>
                                </div>
                                <div class="col-12">
                                    <label for="message" class="form-label">Message</label>
                                    <textarea id="message" name="message" class="form-control" rows="6" placeholder="Write your message here..." required></textarea>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-lg">Send message</button>
                                </div>
                            </form>
                        </section>
                    </div>
                </div>
            </div>
        </section>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

        <footer>
            <p style="text-align: center; padding: 20px; margin-bottom:0; background-color: #cb7e62; color: black;">&copy; 2026, La Petite Douceur. All rights reserved.</p>
        </footer>
    </body>
    
</html>
